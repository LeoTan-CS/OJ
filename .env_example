# Database
DATABASE_URL="file:./dev.db"

# Auth
# Use a long random value in production.
AUTH_SECRET="change-me"

# Judge model for ranking and upload security review
# Use an OpenAI-compatible /v1 base URL, or set JUDGE_API_PROVIDER=ollama for Ollama.
JUDGE_API_BASE_URL="http://127.0.0.1:11434/v1"
JUDGE_API_KEY="ollama"
JUDGE_MODEL="qwen2.5:7b"
JUDGE_API_PROVIDER="ollama"
JUDGE_OLLAMA_KEEP_ALIVE="5m"

# Model runtime
MODEL_TEST_TIMEOUT_MS=300000
MODEL_SINGULARITY_IMAGE="/root/OJ/runtime/model-eval.sif"
MODEL_SINGULARITY_COMMAND="singularity"
MODEL_SINGULARITY_SCRATCH_ROOT="/tmp"
MODEL_SINGULARITY_ENABLE_NV=1
MODEL_SINGULARITY_READONLY_BINDS=""

# Runtime image pull helper
MODEL_RUNTIME_DOCKER_IMAGE="huggingface/transformers-pytorch-gpu:latest"
MODEL_RUNTIME_FORCE_PULL=0

# Container ML defaults
PYTORCH_ENABLE_MPS_FALLBACK=1
