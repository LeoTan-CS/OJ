generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String           @id @default(cuid())
  username     String           @unique
  passwordHash String
  nickname     String
  role         String           @default("USER")
  groupId      String?
  enabled      Boolean          @default(true)
  createdAt    DateTime         @default(now())
  group        Group?           @relation(fields: [groupId], references: [id], onDelete: SetNull)
  models       ModelArtifact[]
  uploadRecords ModelUploadRecord[]
  testBatches  ModelTestBatch[] @relation("ModelTestBatchCreator")
}

model Group {
  id            String              @id @default(cuid())
  name          String              @unique
  createdAt     DateTime            @default(now())
  users         User[]
  models        ModelArtifact[]
  uploadRecords ModelUploadRecord[]
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ModelArtifact {
  id               String            @id @default(cuid())
  userId           String            @unique
  groupId          String?
  name             String
  originalFilename String
  archivePath      String
  packageDir       String
  entrypointPath   String
  enabled          Boolean           @default(true)
  createdAt        DateTime          @default(now())
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  group            Group?            @relation(fields: [groupId], references: [id], onDelete: SetNull)
  uploadRecords    ModelUploadRecord[]
  results          ModelTestResult[]

  @@index([groupId])
}

model ModelUploadRecord {
  id               String        @id @default(cuid())
  modelId          String
  groupId          String?
  userId           String
  originalFilename String
  archivePath      String
  packageDir       String
  entrypointPath   String
  uploadedAt       DateTime      @default(now())
  model            ModelArtifact @relation(fields: [modelId], references: [id], onDelete: Cascade)
  group            Group?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, uploadedAt])
  @@index([userId, uploadedAt])
  @@index([modelId, uploadedAt])
}

model ModelTestBatch {
  id                String            @id @default(cuid())
  kind              String            @default("TEST")
  status            String            @default("PENDING")
  question          String?
  createdById       String
  createdAt         DateTime          @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  judgeStatus       String            @default("NOT_REQUIRED")
  judgeInputPath    String?
  judgeRawResponse  String?
  judgeRankingsJson String?
  judgeReport       String?
  judgeError        String?
  judgeStartedAt    DateTime?
  judgeCompletedAt  DateTime?
  createdBy         User              @relation("ModelTestBatchCreator", fields: [createdById], references: [id], onDelete: Cascade)
  results           ModelTestResult[]
}

model ModelTestResult {
  id            String          @id @default(cuid())
  batchId       String
  modelId       String
  status        String          @default("PENDING")
  durationMs    Int?
  peakMemoryKb  Int?
  outputPath    String?
  outputPreview String?
  error         String?
  createdAt     DateTime        @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  batch         ModelTestBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  model         ModelArtifact   @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([batchId, modelId])
}
